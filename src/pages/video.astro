---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { Image } from "astro:assets";
import imgAsset1 from "../assets/thumbnails/web1.png";
import imgAsset2 from "../assets/thumbnails/web2.png";
---

<BaseLayout
  title="Video Portfolio | Frame Of Rangga"
  description="Portofolio videografi Rangga Danuarta brand video, dokumentasi event, konten sosial media, dan video promosi dengan pendekatan cinematic storytelling."
  ogImage="https://for-portfolio-mu.vercel.app/assets/og/og-video.jpg"
  ogUrl="https://for-portfolio-mu.vercel.app/video"
  hasGlightbox={true}
>
  <Navbar slot="navbar" activePage="video" />

  <!-- PAGE HERO Stitch Reference -->
  <section class="page-hero stitch-hero" transition:animate="fade">
    <div class="page-hero-bg-glow" aria-hidden="true"></div>
    <div class="page-hero-inner stitch-hero-inner">
      <h1 class="stitch-hero-title">
        Cinematic <span class="stitch-hero-accent">Work.</span>
      </h1>
      <p class="stitch-hero-sub">
        Exploring stories through motion and light. A curated collection of brand narratives, documentaries, and creative experiments.
      </p>
    </div>
  </section>

  <!-- VIDEO GALLERY Stitch Layout -->
  <section class="video-section" transition:animate="fade">

    <!-- Filter Bar Stitch pill style -->
    <div class="filter-bar fade-up" aria-label="Filter by category">
      <button class="filter-btn active" data-filter="all">Semua</button>
      <button class="filter-btn" data-filter="brand">Brand Video</button>
      <button class="filter-btn" data-filter="dokumentasi">Dokumentasi</button>
      <button class="filter-btn" data-filter="sosmed">Konten Sosmed</button>
      <button class="filter-btn" data-filter="promosi">Promosi</button>
    </div>

    <!-- Video Grid -->
    <div class="stitch-video-grid fade-up">

      <!-- FEATURED VIDEO CARD Full width featured -->
      <a class="stitch-video-card stitch-video-card-featured glightbox"
         href="https://www.youtube.com/watch?v=iVcwjQdDL74"
         data-type="video"
         data-source="youtube"
         data-gallery="videos"
         data-category="dokumentasi">

        <div class="stitch-video-thumb-wrap">
          <Image             src="https://img.youtube.com/vi/iVcwjQdDL74/maxresdefault.jpg"
            alt="The Coastal Escape Featured Project"
            loading="lazy"
            width="1280"
            height="549"
          />
          <div class="stitch-video-thumb-overlay"></div>
        </div>

        <div class="stitch-video-card-featured-body">
          <div class="stitch-video-card-featured-left">
            <span class="stitch-featured-badge">Featured Project</span>
            <h2 class="stitch-video-card-featured-title">The Coastal Escape</h2>
            <p class="stitch-video-card-featured-desc">Rekap visual dari footage alam dan pantai dengan pendekatan cinematic editing yang mendalam.</p>
          </div>
          <div class="stitch-video-card-featured-right">
            <div class="stitch-duration-block">
              <span class="stitch-duration-label">Duration</span>
              <span class="stitch-duration-value">02:30</span>
            </div>
            <button class="stitch-play-btn stitch-play-btn-lg" aria-label="Play video">
              <i class="fas fa-play"></i>
            </button>
          </div>
        </div>
      </a>

      <!-- Regular Video Cards 2 column grid -->
      <div class="stitch-video-grid-regular">

        <!-- Card 1: Brand Video -->
        <a class="stitch-video-card stitch-video-card-regular glightbox"
           href="https://www.youtube.com/watch?v=dQw4w9WgXcQ"
           data-type="video"
           data-source="youtube"
           data-gallery="videos"
           data-category="brand">
          <div class="stitch-video-thumb-wrap">
            <Image               src={imgAsset1}
              alt="Brand Video"
              loading="lazy"
              width="640"
              height="360"
            />
            <div class="stitch-duration-badge">3:45</div>
            <div class="stitch-video-play-overlay">
              <div class="stitch-play-btn">
                <i class="fas fa-play"></i>
              </div>
            </div>
          </div>
          <div class="stitch-video-card-footer">
            <div class="stitch-video-card-info">
              <h3 class="stitch-video-card-title">Brand Video: Client Project</h3>
              <p class="stitch-video-card-meta">Brand Video &bull; 2024</p>
            </div>
          </div>
        </a>

        <!-- Card 2: Dokumentasi -->
        <a class="stitch-video-card stitch-video-card-regular glightbox"
          href="https://youtu.be/34ju_IWZc34"
           data-type="video"
           data-source="youtube"
           data-gallery="videos"
           data-category="dokumentasi">
          <div class="stitch-video-thumb-wrap">
            <Image               src="https://img.youtube.com/vi/34ju_IWZc34/maxresdefault.jpg"
              alt="Dokumentasi Event"
              loading="lazy"
              width="640"
              height="360"
            />
            <div class="stitch-duration-badge">3:40</div>
            <div class="stitch-video-play-overlay">
              <div class="stitch-play-btn">
                <i class="fas fa-play"></i>
              </div>
            </div>
          </div>
          <div class="stitch-video-card-footer">
            <div class="stitch-video-card-info">
              <h3 class="stitch-video-card-title">Dokumentasi Event</h3>
              <p class="stitch-video-card-meta">Dokumentasi &bull; 2024</p>
            </div>
          </div>
        </a>

        <!-- Card 3: Konten Sosmed -->
        <a class="stitch-video-card stitch-video-card-regular glightbox"
           href="https://www.youtube.com/watch?v=dQw4w9WgXcQ"
           data-type="video"
           data-source="youtube"
           data-gallery="videos"
           data-category="sosmed">
          <div class="stitch-video-thumb-wrap">
            <Image               src={imgAsset1}
              alt="Konten Sosial Media"
              loading="lazy"
              width="640"
              height="360"
            />
            <div class="stitch-duration-badge">0:30</div>
            <div class="stitch-video-play-overlay">
              <div class="stitch-play-btn">
                <i class="fas fa-play"></i>
              </div>
            </div>
          </div>
          <div class="stitch-video-card-footer">
            <div class="stitch-video-card-info">
              <h3 class="stitch-video-card-title">Konten Sosial Media</h3>
              <p class="stitch-video-card-meta">Konten Sosmed &bull; 2024</p>
            </div>
          </div>
        </a>

        <!-- Card 4: Promosi -->
        <a class="stitch-video-card stitch-video-card-regular glightbox"
           href="https://www.youtube.com/watch?v=dQw4w9WgXcQ"
           data-type="video"
           data-source="youtube"
           data-gallery="videos"
           data-category="promosi">
          <div class="stitch-video-thumb-wrap">
            <Image               src={imgAsset2}
              alt="Video Promosi"
              loading="lazy"
              width="640"
              height="360"
            />
            <div class="stitch-duration-badge">1:00</div>
            <div class="stitch-video-play-overlay">
              <div class="stitch-play-btn">
                <i class="fas fa-play"></i>
              </div>
            </div>
          </div>
          <div class="stitch-video-card-footer">
            <div class="stitch-video-card-info">
              <h3 class="stitch-video-card-title">Video Promosi Produk</h3>
              <p class="stitch-video-card-meta">Promosi &bull; 2024</p>
            </div>
          </div>
        </a>

      </div>
    </div>

  </section>

  <Footer slot="footer" variant="minimal" />
</BaseLayout>

<style>
  /* =============================================
     STITCH VIDEO PAGE Scoped styles
     Matches: stitch/video_portfolio_redesign/code.html
     ============================================= */

  /* Hero */
  .stitch-hero {
    padding: 140px 48px 80px;
    max-width: 1280px;
    margin: 0 auto;
  }

  .stitch-hero-inner {
    max-width: 100%;
    text-align: center;
  }

  .stitch-hero-title {
    font-family: 'Manrope', sans-serif;
    font-size: clamp(48px, 7vw, 96px);
    font-weight: 800;
    letter-spacing: -2px;
    line-height: 1.05;
    color: var(--text-primary);
    margin-bottom: 20px;
  }

  .stitch-hero-accent {
    background: var(--gradient-text);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .stitch-hero-sub {
    font-size: 17px;
    line-height: 1.7;
    color: var(--text-secondary);
    max-width: 600px;
    margin: 0 auto;
  }

  /* Filter Bar */
  .filter-bar {
    padding: 0 48px;
    margin-bottom: 48px;
  }

  .filter-btn {
    background: var(--surface-container-highest);
    border: 1px solid rgba(163, 166, 255, 0.08);
    color: var(--text-secondary);
    font-family: 'Inter', sans-serif;
    font-weight: 600;
    font-size: 13px;
    padding: 9px 22px;
    border-radius: 9999px;
    cursor: pointer;
    white-space: nowrap;
    transition: all 0.3s ease;
  }

  .filter-btn:hover {
    background: var(--surface-bright);
    color: var(--accent-primary);
    border-color: rgba(163, 166, 255, 0.15);
    transform: translateY(-2px);
  }

  .filter-btn.active {
    background: var(--accent-secondary-container);
    border-color: rgba(193, 128, 255, 0.3);
    color: #e9cdff;
  }

  /* Video Section */
  .video-section {
    padding: 0 48px 80px;
    max-width: 1280px;
    margin: 0 auto;
  }

  /* Bento-style grid: featured + 2-col grid */
  .stitch-video-grid {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  /* Featured Card */
  .stitch-video-card-featured {
    display: block;
    position: relative;
    border-radius: 16px;
    overflow: hidden;
    background: var(--surface-container);
    border: 1px solid rgba(163, 166, 255, 0.08);
    cursor: pointer;
    aspect-ratio: 21 / 9;
    transition: transform 0.4s ease, box-shadow 0.3s ease;
  }

  .stitch-video-card-featured:hover {
    transform: translateY(-6px);
    box-shadow: 0 20px 48px rgba(0, 0, 0, 0.4);
  }

  .stitch-video-thumb-wrap {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
  }

  .stitch-video-card-featured .stitch-video-thumb-wrap {
    position: absolute;
    inset: 0;
  }

  .stitch-video-thumb-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.7s ease;
  }

  .stitch-video-card-featured:hover .stitch-video-thumb-wrap img {
    transform: scale(1.04);
  }

  .stitch-video-thumb-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(6, 14, 32, 0.95) 0%,
      rgba(6, 14, 32, 0.4) 50%,
      transparent 100%
    );
  }

  /* Featured body: text left, controls right */
  .stitch-video-card-featured-body {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 40px 48px;
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 24px;
  }

  .stitch-featured-badge {
    display: inline-block;
    padding: 5px 14px;
    border-radius: 9999px;
    background: rgba(163, 166, 255, 0.15);
    border: 1px solid rgba(163, 166, 255, 0.25);
    color: var(--accent-primary);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: 14px;
    backdrop-filter: blur(8px);
  }

  .stitch-video-card-featured-title {
    font-family: 'Manrope', sans-serif;
    font-size: clamp(24px, 3vw, 44px);
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 8px;
    line-height: 1.1;
  }

  .stitch-video-card-featured-desc {
    font-size: 14px;
    color: var(--text-secondary);
    max-width: 500px;
    line-height: 1.5;
  }

  .stitch-video-card-featured-right {
    display: flex;
    align-items: center;
    gap: 20px;
    flex-shrink: 0;
  }

  .stitch-duration-block {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 2px;
  }

  .stitch-duration-label {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-secondary);
  }

  .stitch-duration-value {
    font-family: 'Manrope', sans-serif;
    font-size: 22px;
    font-weight: 700;
    color: var(--text-primary);
  }

  /* Play Button */
  .stitch-play-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: var(--accent-primary);
    color: #0f00a4;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    flex-shrink: 0;
  }

  .stitch-play-btn i {
    display: flex;
  }

  .stitch-play-btn-lg {
    width: 64px;
    height: 64px;
    font-size: 22px;
    box-shadow: 0 0 30px rgba(163, 166, 255, 0.35);
  }

  .stitch-video-card-featured:hover .stitch-play-btn-lg {
    transform: scale(1.1);
    box-shadow: 0 0 40px rgba(163, 166, 255, 0.5);
  }

  /* Regular Grid */
  .stitch-video-grid-regular {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }

  /* Regular Card */
  .stitch-video-card-regular {
    display: block;
    border-radius: 16px;
    overflow: hidden;
    background: var(--surface-container-high);
    border: 1px solid rgba(163, 166, 255, 0.08);
    cursor: pointer;
    transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1),
                box-shadow 0.3s ease,
                border-color 0.3s ease;
  }

  .stitch-video-card-regular:hover {
    transform: translateY(-6px);
    border-color: rgba(163, 166, 255, 0.18);
    box-shadow: 0 20px 48px rgba(0, 0, 0, 0.4);
  }

  .stitch-video-card-regular .stitch-video-thumb-wrap {
    aspect-ratio: 16 / 9;
    overflow: hidden;
  }

  .stitch-video-card-regular:hover .stitch-video-thumb-wrap img {
    transform: scale(1.05);
  }

  /* Duration badge top right */
  .stitch-duration-badge {
    position: absolute;
    top: 14px;
    right: 14px;
    padding: 4px 10px;
    border-radius: 8px;
    background: rgba(0, 0, 0, 0.65);
    backdrop-filter: blur(8px);
    color: #fff;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.02em;
    z-index: 2;
  }

  /* Play overlay on hover */
  .stitch-video-play-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.25);
    opacity: 0;
    transition: opacity 0.3s ease;
    z-index: 1;
  }

  .stitch-video-card-regular:hover .stitch-video-play-overlay {
    opacity: 1;
  }

  .stitch-play-btn:not(.stitch-play-btn-lg) {
    width: 52px;
    height: 52px;
    font-size: 16px;
    background: rgba(255, 255, 255, 0.15);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.25);
    color: #fff;
  }

  .stitch-video-card-regular:hover .stitch-play-btn:not(.stitch-play-btn-lg) {
    transform: scale(1.1);
  }

  /* Card footer */
  .stitch-video-card-footer {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    padding: 18px 20px;
    gap: 12px;
  }

  .stitch-video-card-info {
    flex: 1;
  }

  .stitch-video-card-title {
    font-family: 'Manrope', sans-serif;
    font-size: 18px;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 5px;
    line-height: 1.2;
  }

  .stitch-video-card-meta {
    font-size: 12px;
    color: var(--text-secondary);
    font-weight: 500;
  }

  .stitch-more-btn {
    background: none;
    border: none;
    color: var(--text-secondary);
    cursor: pointer;
    padding: 4px;
    font-size: 14px;
    transition: color 0.2s ease;
    flex-shrink: 0;
    margin-top: 3px;
  }

  .stitch-more-btn:hover {
    color: var(--accent-primary);
  }

  /* Responsive iPad (768px) */
  @media (max-width: 768px) {
    .stitch-hero {
      padding: 100px 24px 48px;
    }

    .stitch-hero-title {
      font-size: clamp(36px, 9vw, 60px);
    }

    .filter-bar,
    .video-section {
      padding-left: 20px;
      padding-right: 20px;
    }

    .filter-bar {
      gap: 8px;
      overflow-x: auto;
      flex-wrap: nowrap;
      scrollbar-width: none;
      -webkit-overflow-scrolling: touch;
      margin-bottom: 32px;
    }

    .filter-bar::-webkit-scrollbar { display: none; }

    .stitch-video-card-featured {
      aspect-ratio: 16 / 9;
    }

    .stitch-video-grid-regular {
      grid-template-columns: repeat(2, 1fr);
      gap: 14px;
    }

    .stitch-video-card-featured-body {
      padding: 20px 24px;
      flex-direction: column;
      align-items: flex-start;
      gap: 12px;
    }

    .stitch-duration-block {
      display: none;
    }
  }

  /* Responsive Mobile (480px) */
  @media (max-width: 600px) {
    .stitch-hero {
      padding: 88px 20px 40px;
    }

    .stitch-hero-title {
      font-size: clamp(32px, 11vw, 48px);
    }

    .stitch-hero-sub {
      font-size: 15px;
    }

    .filter-bar {
      padding: 0 20px 8px;
      margin-bottom: 24px;
    }

    .filter-btn {
      flex-shrink: 0;
      font-size: 12px;
      padding: 8px 16px;
    }

    .stitch-video-card-featured {
      aspect-ratio: 16 / 9;
      border-radius: 12px;
    }

    .stitch-video-grid-regular {
      grid-template-columns: 1fr;
      gap: 12px;
    }

    .stitch-video-card-featured-body {
      padding: 16px 20px;
    }

    .stitch-video-card-featured-title {
      font-size: clamp(18px, 5vw, 24px);
    }

    .stitch-video-card-regular {
      border-radius: 12px;
    }
  }

  @media (max-width: 480px) {
    .stitch-hero {
      padding: 80px 20px 36px;
    }

    .stitch-video-card-featured-body {
      padding: 14px 16px;
    }

    .stitch-play-btn-lg {
      width: 44px;
      height: 44px;
      font-size: 14px;
    }
  }
</style>

<script is:inline>
  /* ---------- GLIGHTBOX (YouTube embed) ---------- */
  document.addEventListener('DOMContentLoaded', function initGL() {
    if (typeof GLightbox === 'undefined') {
      setTimeout(initGL, 100);
      return;
    }
    GLightbox({
      selector: '.glightbox',
      touchNavigation: true,
      loop: false,
      autoplayVideos: true,
    });
  });

  /* ---------- VIDEO FILTER ---------- */
  (function() {
    const filterBar = document.querySelector('.filter-bar');
    if (!filterBar) return;

    const btns = filterBar.querySelectorAll('.filter-btn');
    const featuredCard = document.querySelector('.stitch-video-card-featured');
    const regularGrid = document.querySelector('.stitch-video-grid-regular');
    if (!regularGrid) return;

    btns.forEach(function(btn) {
      btn.addEventListener('click', function() {
        const filter = btn.dataset.filter;

        // Update active button
        btns.forEach(function(b) { b.classList.remove('active'); });
        btn.classList.add('active');

        // Filter regular cards
        const cards = regularGrid.querySelectorAll('.stitch-video-card-regular');
        cards.forEach(function(card) {
          const cat = card.dataset.category || '';
          if (filter === 'all' || cat === filter) {
            card.style.display = '';
          } else {
            card.style.display = 'none';
          }
        });

        // Also filter featured card
        if (featuredCard) {
          const featCat = featuredCard.dataset.category || '';
          featuredCard.style.display =
            (filter === 'all' || featCat === filter) ? '' : 'none';
        }
      });
    });
  })();
</script>
