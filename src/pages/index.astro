---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import ServiceCard from "../components/ServiceCard.astro";
import TestimonialCard from "../components/TestimonialCard.astro";
import { waLink } from "../utils/whatsapp.js";
import { Image } from "astro:assets";
import imgAsset1 from "../assets/design/social/carousels 1.png";
import imgAsset2 from "../assets/foto/foto cover halaman utama.jpg";
import imgAsset3 from "../assets/foto/wedding/ultah raden 2 landscape.JPG";
import imgAsset4 from "../assets/thumbnails/thumbnail-video.png";
import imgAsset5 from "../assets/thumbnails/web2.png";
import imgAsset6 from "../assets/thumbnails/thumbnail-design.png";
import imgAsset7 from "../assets/foto/about rangga.jpg";
import imgAsset8 from "../assets/logos/ptnr-tokopedia.png";
import imgAsset9 from "../assets/logos/ptnr-kitabisa.png";
import imgAsset10 from "../assets/logos/ptnr-shopee.png";
import imgAsset11 from "../assets/logos/ptnr-bankqurban.png";
import imgAsset12 from "../assets/logos/ptnr-shinepartner.png";
import imgAsset13 from "../assets/logos/ptnr-mandiri.png";
---

<BaseLayout
  title="Frame Of Rangga | Visual Storyteller Foto, Video, Design & Web"
  description="Rangga Danuarta, Visual Storyteller berbasis di Depok. Spesialis fotografi komersial, videografi, brand design, dan web development untuk brand dan bisnis Anda."
  ogImage="https://for-portfolio-mu.vercel.app/assets/og/og-default.jpg"
  ogUrl="https://for-portfolio-mu.vercel.app/"
  hasHeroPreload={true}
>
  <!-- Navbar slot -->
  <Navbar slot="navbar" activePage="home" />

  <!-- HERO Stitch Nocturnal Design -->
  <header class="stitch-hero" id="hero" transition:animate="fade">
    <!-- Background glow blobs (desktop) -->
    <div class="stitch-hero-glow-r" aria-hidden="true"></div>
    <div class="stitch-hero-glow-l" aria-hidden="true"></div>

    <!-- Background image -->
    <div class="stitch-hero-bg" aria-hidden="true">
      <Image         src={imgAsset1}
        alt="Hero background Frame Of Rangga portfolio showcase"
        class="stitch-hero-bg-img"
        loading="eager"
        fetchpriority="high"
      />
      <div class="stitch-hero-bg-overlay"></div>
    </div>

    <!-- Hero grid: text left, portrait right -->
    <div class="stitch-hero-grid">
      <!-- Text Content -->
      <div class="stitch-hero-content">
        <!-- Badge -->
        <span class="stitch-badge"> Visual Storyteller </span>
        <!-- H1 -->
        <h1 class="stitch-hero-title">
          Frame of<br />
          <span class="stitch-hero-title-accent">Rangga</span>
        </h1>
        <!-- Description -->
        <p class="stitch-hero-desc">
          Crafting visual narratives through the lens of cinematic precision and
          editorial depth. Creative Direction for the digital age.
        </p>
      </div>

      <!-- Portrait -->
      <div class="stitch-hero-portrait">
        <div class="stitch-hero-portrait-inner">
          <Image             src={imgAsset2}
            alt="Rangga Danuarta Frame Of Rangga"
            class="stitch-hero-portrait-img"
            loading="eager"
            fetchpriority="high"
          />
          <!-- Floating badge -->
          <div class="stitch-hero-float-badge">
            <div class="stitch-float-badge-icon">
              <span class="material-symbols-outlined stitch-icon-filled"
                >verified</span
              >
            </div>
            <div>
              <p class="stitch-float-badge-sub">Visual Storyteller</p>
              <p class="stitch-float-badge-name">Rangga Danuarta</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </header>

  <!-- Divider -->
  <div class="section-divider" aria-hidden="true"></div>

  <!-- AVAILABILITY BADGE -->
  <div class="availability-banner">
    <div class="availability-inner">
      <span class="availability-badge available">
        <span class="availability-dot"></span>
        Tersedia untuk project baru
      </span>
      <a
        href={waLink("collab")}
        target="_blank"
        rel="noopener"
        class="availability-cta"
      >
        <i class="fab fa-whatsapp"></i> Hubungi sekarang
      </a>
    </div>
  </div>

  <!-- EXPLORE CATEGORIES -->
  <section class="cat-section" id="categories" transition:animate="fade">
    <div class="cat-inner">
      <div class="cat-header fade-up">
        <h2 class="cat-title">Explore Categories</h2>
        <div class="cat-title-line"></div>
      </div>
      <div class="cat-grid">
        <a href="/foto" class="cat-card cat-card-foto">
          <Image             src={imgAsset3}
            alt="Birthday Photography Momen perayaan oleh Rangga Danuarta"
            loading="lazy"
          />
          <div class="cat-card-overlay"></div>
          <div class="cat-card-content">
            <span class="cat-card-label">Capturing Essence</span>
            <h3 class="cat-card-title">Foto</h3>
          </div>
          <div class="cat-card-arrow">
            <span class="material-symbols-outlined">arrow_outward</span>
          </div>
        </a>
        <a href="/video" class="cat-card cat-card-video">
          <Image             src={imgAsset4}
            alt="Videography Portfolio Brand video dan dokumentasi event oleh Frame Of Rangga"
            loading="lazy"
          />
          <div class="cat-card-overlay"></div>
          <div class="cat-card-content">
            <span class="cat-card-label">Motion Theory</span>
            <h3 class="cat-card-title">Video</h3>
          </div>
        </a>
        <a href="/website" class="cat-card cat-card-website">
          <Image             src={imgAsset5}
            alt="Web Development Portfolio Portfolio dan landing page oleh Frame Of Rangga"
            loading="lazy"
          />
          <div class="cat-card-overlay"></div>
          <div class="cat-card-content">
            <span class="cat-card-label">Web App</span>
            <h3 class="cat-card-title">Website</h3>
          </div>
        </a>
        <a href="/design" class="cat-card cat-card-design">
          <Image             src={imgAsset6}
            alt="Brand Design Portfolio Identity dan advertising design oleh Frame Of Rangga"
            loading="lazy"
          />
          <div class="cat-card-overlay"></div>
          <div class="cat-card-content">
            <span class="cat-card-label">Visual Social Media</span>
            <h3 class="cat-card-title">Design</h3>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- Divider -->
  <div class="section-divider" aria-hidden="true"></div>

  <!-- ABOUT -->
  <section class="about" id="about" transition:animate="fade">
    <div class="about-inner">
      <div class="about-photo fade-up">
        <div class="about-photo-wrap">
          <Image             src={imgAsset7}
            alt="Rangga Danuarta"
            loading="lazy"
            onerror="this.style.display='none'"
          />
        </div>
      </div>
      <div class="about-text fade-up">
        <span class="section-label gradient-label">TENTANG FOR</span>
        <h2 class="section-title">About Me</h2>
        <p class="about-bio">
          Saya Rangga Danuarta, seorang Visual Storyteller dan Creative
          Professional berbasis di Depok, Indonesia. Dengan pengalaman lebih
          dari 4 tahun di bidang fotografi, videografi, brand design, dan web
          development, saya berdedikasi untuk menghadirkan karya visual yang
          tidak hanya estetis, tetapi juga berdampak nyata bagi brand dan bisnis
          klien.
        </p>
        <p class="about-bio">
          Setiap project dikerjakan dengan pendekatan yang terstruktur: mulai
          dari riset mendalam, pengembangan konsep, eksekusi teknis, hingga
          final delivery yang memenuhi standar kualitas tertinggi. Saya percaya
          bahwa visual yang kuat adalah fondasi dari komunikasi brand yang
          efektif.
        </p>
        <div class="about-stats">
          <div class="stat-card">
            <span class="stat-number" data-target="4">0</span>
            <span class="stat-label">Years</span>
          </div>
          <div class="stat-card">
            <span class="stat-number" data-target="50">0</span>
            <span class="stat-label">Projects</span>
          </div>
          <div class="stat-card">
            <span class="stat-number" data-target="4">0</span>
            <span class="stat-label">Services</span>
          </div>
          <div class="stat-card">
            <span class="stat-number" data-target="10">0</span>
            <span class="stat-label">Brand Partners</span>
          </div>
        </div>
        <a
          href={waLink("collab")}
          target="_blank"
          rel="noopener"
          class="btn btn-ghost"
        >
          <i class="fab fa-whatsapp"></i> Chat via WhatsApp
        </a>
      </div>
    </div>
  </section>

  <!-- Divider -->
  <div class="section-divider" aria-hidden="true"></div>

  <!-- BRANDS -->
  <section class="brands" id="brands" transition:animate="fade">
    <div class="brands-inner fade-up">
      <p class="brands-label">Trusted by brands &amp; clients</p>
      <div class="logo-strip">
        <div class="logo-item">
          <Image             src={imgAsset8}
            alt="Tokopedia"
            loading="lazy"
          />
        </div>
        <div class="logo-item">
          <Image             src={imgAsset9}
            alt="KitaBisa"
            loading="lazy"
          />
        </div>
        <div class="logo-item">
          <Image             src={imgAsset10}
            alt="Shopee"
            loading="lazy"
          />
        </div>
        <div class="logo-item">
          <Image             src={imgAsset11}
            alt="Bank Qurban"
            loading="lazy"
          />
        </div>
        <div class="logo-item">
          <Image             src={imgAsset12}
            alt="Shinepartner"
            loading="lazy"
          />
        </div>
        <div class="logo-item">
          <Image             src={imgAsset13}
            alt="Mandiri"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Divider -->
  <div class="section-divider" aria-hidden="true"></div>

  <!-- SERVICES -->
  <section class="services" id="services" transition:animate="fade">
    <div class="services-inner">
      <div class="services-header fade-up">
        <span class="section-label gradient-label">WHAT I DO</span>
        <h2 class="section-title">Services</h2>
        <p class="section-sub" style="text-align: center;">
          Solusi kreatif lengkap untuk brand dan bisnis Anda
        </p>
      </div>
      <div class="services-grid">
        <ServiceCard
          icon="fas fa-camera"
          title="Photography"
          description="Foto komersial, birthday & event, editorial, dan automotive dengan pendekatan storytelling yang kuat dan estetik yang tajam."
          whatsappKey="foto_general"
        />
        <ServiceCard
          icon="fas fa-video"
          title="Videography"
          description="Produksi video mulai dari konsep hingga final cut. Cocok untuk konten brand, dokumentasi acara, dan video promosi."
          whatsappKey="video_general"
        />
        <ServiceCard
          icon="fas fa-palette"
          title="Brand Design"
          description="Identitas visual, desain sosial media, poster, dan materi iklan yang membangun karakter brand secara konsisten."
          whatsappKey="design_general"
        />
        <ServiceCard
          icon="fas fa-code"
          title="Web Development"
          description="Website portofolio, landing page, dan undangan digital yang responsif, cepat, dan berorientasi pada pengalaman pengguna."
          whatsappKey="web_general"
        />
      </div>
    </div>
  </section>

  <!-- Divider -->
  <div class="section-divider" aria-hidden="true"></div>

  <!-- =============================================
       PRICING SECTION
       ============================================= -->
  <section class="pricing-section" id="pricing" transition:animate="fade">
    <div class="pricing-inner">
      <div class="pricing-header fade-up">
        <span class="section-label gradient-label">INVESTASI</span>
        <h2 class="section-title">Harga Transparan, Kualitas Terukur</h2>
        <p class="section-sub">
          Semua paket bisa dikustomisasi sesuai kebutuhan project kamu.
          Konsultasi gratis chat via WhatsApp untuk negosiasi.
        </p>
      </div>
      <div class="pricing-grid fade-up">
        <!-- Photography -->
        <div class="pricing-card">
          <div class="pricing-card-header">
            <div class="pricing-icon">
              <i class="fas fa-camera"></i>
            </div>
            <h3 class="pricing-card-title">Photography</h3>
          </div>
          <div class="pricing-price">
            <span class="pricing-from">Mulai dari</span>
            <span class="pricing-amount">Rp 250.000</span>
            <span class="pricing-unit">/ sesi</span>
          </div>
          <ul class="pricing-features">
            <li><i class="fas fa-check"></i> 1 sesi foto (2-3 jam)</li>
            <li><i class="fas fa-check"></i> 20+ foto final edited</li>
            <li><i class="fas fa-check"></i> Online gallery share</li>
            <li><i class="fas fa-check"></i> Revisi ringan included</li>
          </ul>
          <a
            href={waLink("foto_general")}
            target="_blank"
            rel="noopener"
            class="pricing-cta"
          >
            <i class="fab fa-whatsapp"></i> Tanya Paket
          </a>
        </div>

        <!-- Video / Video Editing -->
        <div class="pricing-card pricing-card-featured">
          <div class="pricing-badge">Paling Dicari</div>
          <div class="pricing-card-header">
            <div class="pricing-icon">
              <i class="fas fa-video"></i>
            </div>
            <h3 class="pricing-card-title">Video &amp; Editing</h3>
          </div>
          <div class="pricing-price">
            <span class="pricing-from">Mulai dari</span>
            <span class="pricing-amount">Rp 200.000</span>
            <span class="pricing-unit">/ Video</span>
          </div>
          <ul class="pricing-features">
            <li><i class="fas fa-check"></i> Konsep &amp; storyboard</li>
            <li><i class="fas fa-check"></i> Shooting atau editing saja</li>
            <li><i class="fas fa-check"></i> Revisi hingga final cut</li>
            <li><i class="fas fa-check"></i> Format: MP4, 1080p</li>
          </ul>
          <a
            href={waLink("video_general")}
            target="_blank"
            rel="noopener"
            class="pricing-cta pricing-cta-featured"
          >
            <i class="fab fa-whatsapp"></i> Tanya Paket
          </a>
        </div>

        <!-- Brand Design -->
        <div class="pricing-card">
          <div class="pricing-card-header">
            <div class="pricing-icon">
              <i class="fas fa-palette"></i>
            </div>
            <h3 class="pricing-card-title">Brand Design</h3>
          </div>
          <div class="pricing-price">
            <span class="pricing-from">Mulai dari</span>
            <span class="pricing-amount">Rp 100.000</span>
            <span class="pricing-unit">/ Design</span>
          </div>
          <ul class="pricing-features">
            <li><i class="fas fa-check"></i> 1 piece desain (poster/sosmed)</li>
            <li><i class="fas fa-check"></i> Brand identity kit</li>
            <li><i class="fas fa-check"></i> Source file included</li>
            <li><i class="fas fa-check"></i> Revisi 2x free</li>
          </ul>
          <a
            href={waLink("design_general")}
            target="_blank"
            rel="noopener"
            class="pricing-cta"
          >
            <i class="fab fa-whatsapp"></i> Tanya Paket
          </a>
        </div>

        <!-- Web Development -->
        <div class="pricing-card">
          <div class="pricing-card-header">
            <div class="pricing-icon">
              <i class="fas fa-code"></i>
            </div>
            <h3 class="pricing-card-title">Web Development</h3>
          </div>
          <div class="pricing-price">
            <span class="pricing-from">Mulai dari</span>
            <span class="pricing-amount">Rp 250.000</span>
            <span class="pricing-unit">/ project</span>
          </div>
          <ul class="pricing-features">
            <li><i class="fas fa-check"></i> Portfolio atau landing page</li>
            <li><i class="fas fa-check"></i> Responsive di semua device</li>
            <li><i class="fas fa-check"></i> Fast loading &amp; SEO-ready</li>
            <li><i class="fas fa-check"></i> Deployment included</li>
          </ul>
          <a
            href={waLink("web_general")}
            target="_blank"
            rel="noopener"
            class="pricing-cta"
          >
            <i class="fab fa-whatsapp"></i> Tanya Paket
          </a>
        </div>
      </div>
      <p class="pricing-note fade-up">
        <i class="fas fa-info-circle"></i> Harga di atas adalah estimasi. Harga final
        tergantung scope, kompleksitas, dan deadline project. Konsultasi gratis hubungi
        via WhatsApp.
      </p>
    </div>
  </section>

  <!-- Divider -->
  <div class="section-divider" aria-hidden="true"></div>

  <!-- =============================================
       WORKFLOW SECTION
       ============================================= -->
  <section class="workflow-section" id="workflow" transition:animate="fade">
    <div class="workflow-inner">
      <div class="workflow-header fade-up">
        <span class="section-label gradient-label">CARA KERJA</span>
        <h2 class="section-title">Alur Kerja Dari Brief sampai Delivery</h2>
        <p class="section-sub">
          Proses yang transparan dan terstruktur, supaya kamu tahu apa yang
          diharapkan di setiap tahap.
        </p>
      </div>
      <div class="workflow-steps fade-up">
        <div class="workflow-step">
          <div class="workflow-step-num">01</div>
          <div class="workflow-step-icon"><i class="fas fa-comments"></i></div>
          <h3 class="workflow-step-title">Brief &amp; Konsultasi</h3>
          <p class="workflow-step-desc">
            Ceritakan kebutuhan kamu topik, target audiens, dan goal. Diskusi
            gratis via WhatsApp. Saya bantu clarifikasi ide kamu.
          </p>
        </div>
        <div class="workflow-connector" aria-hidden="true">
          <i class="fas fa-arrow-right"></i>
        </div>
        <div class="workflow-step">
          <div class="workflow-step-num">02</div>
          <div class="workflow-step-icon"><i class="fas fa-lightbulb"></i></div>
          <h3 class="workflow-step-title">Konsep &amp; Pitch</h3>
          <p class="workflow-step-desc">
            Saya kembangkan konsep visual sesuai brief. Moodboard, storyboard,
            atau wireframe dikasih untuk alignment sebelum eksekusi.
          </p>
        </div>
        <div class="workflow-connector" aria-hidden="true">
          <i class="fas fa-arrow-right"></i>
        </div>
        <div class="workflow-step">
          <div class="workflow-step-num">03</div>
          <div class="workflow-step-icon"><i class="fas fa-cogs"></i></div>
          <h3 class="workflow-step-title">Eksekusi &amp; Produksi</h3>
          <p class="workflow-step-desc">
            Proses shooting, editing, atau development dengan update berkala.
            Kamu bisa monitor progress dan kasih feedback mid way.
          </p>
        </div>
        <div class="workflow-connector" aria-hidden="true">
          <i class="fas fa-arrow-right"></i>
        </div>
        <div class="workflow-step">
          <div class="workflow-step-num">04</div>
          <div class="workflow-step-icon"><i class="fas fa-sync-alt"></i></div>
          <h3 class="workflow-step-title">Revisi &amp; Fine-tuning</h3>
          <p class="workflow-step-desc">
            Feedback loop revisi hingga hasil sesuai ekspektasi. Revisi minor
            biasanya free, revisi major dihitung terpisah.
          </p>
        </div>
        <div class="workflow-connector" aria-hidden="true">
          <i class="fas fa-arrow-right"></i>
        </div>
        <div class="workflow-step">
          <div class="workflow-step-num">05</div>
          <div class="workflow-step-icon"><i class="fas fa-download"></i></div>
          <h3 class="workflow-step-title">Delivery Final</h3>
          <p class="workflow-step-desc">
            File final dikirim dalam format yang disepakati. Untuk web: deployed
            dan ready. Untuk desain: print ready atau digital optimized.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Divider -->
  <div class="section-divider" aria-hidden="true"></div>

  <!-- =============================================
       FAQ SECTION
       ============================================= -->
  <section class="faq-section" id="faq" transition:animate="fade">
    <div class="faq-inner">
      <div class="faq-header fade-up">
        <span class="section-label gradient-label">FAQ</span>
        <h2 class="section-title">Pertanyaan yang Sering Diajukan</h2>
      </div>
      <div class="faq-list fade-up">
        <details class="faq-item">
          <summary class="faq-question">
            <span class="faq-q-text"
              >Berapa lama pengerjaan setiap project?</span
            >
            <i class="fas fa-chevron-down faq-chevron"></i>
          </summary>
          <div class="faq-answer">
            Tergantung scope dan kompleksitas. Foto single session: 1-3 hari.
            Video: 3-7 hari. Desain brand: 1-2 minggu. Website: 2-4 minggu.
            Timeline exact akan dikasih setelah brief.
          </div>
        </details>
        <details class="faq-item">
          <summary class="faq-question">
            <span class="faq-q-text">Apakah bisa revisi?</span>
            <i class="fas fa-chevron-down faq-chevron"></i>
          </summary>
          <div class="faq-answer">
            Ya! Setiap project include revisi. Photography: revisi edit 1x.
            Video: revisi 2x. Design: revisi 2x. Website: revisi minor included.
            Revisi major dihitung terpisah tapi biasanya masih reasonable.
          </div>
        </details>
        <details class="faq-item">
          <summary class="faq-question">
            <span class="faq-q-text"
              >Apakah melayani luar Depok atau Jakarta?</span
            >
            <i class="fas fa-chevron-down faq-chevron"></i>
          </summary>
          <div class="faq-answer">
            Untuk photography & videography lokasi, saya bisa ke Jabodetabek.
            Untuk luar area, bisa arrange shoot dengan partner atau via remote
            editing. Web & desain: anywhere, 100% remote.
          </div>
        </details>
        <details class="faq-item">
          <summary class="faq-question">
            <span class="faq-q-text">Bagaimana cara pembayaran?</span>
            <i class="fas fa-chevron-down faq-chevron"></i>
          </summary>
          <div class="faq-answer">
            Pembayaran via transfer bank (BCA, Mandiri, BSI). Skema: 50% DP saat
            konfirmasi, 50% sisanya saat final delivery. Untuk project kecil
            biasanya full payment di awal.
          </div>
        </details>
        <details class="faq-item">
          <summary class="faq-question">
            <span class="faq-q-text"
              >Apakah bisa konsultasi dulu sebelum deal?</span
            >
            <i class="fas fa-chevron-down faq-chevron"></i>
          </summary>
          <div class="faq-answer">
            Absolutely! Konsultasi awal via WhatsApp itu gratis dan tidak
            mengikat. Ceritakan ide kamu, kita diskusi bareng kalau memang
            cocok, lanjut. Kalau tidak, ya tidak apa apa.
          </div>
        </details>
        <details class="faq-item">
          <summary class="faq-question">
            <span class="faq-q-text">File apa saja yang di-deliver?</span>
            <i class="fas fa-chevron-down faq-chevron"></i>
          </summary>
          <div class="faq-answer">
            Foto: JPEG high-res + web-optimized. Video: MP4 (1080p atau sesuai
            request). Desain: PNG/JPG + source file (AI/PSD/Figma). Website:
            deployed + source code. Semua dalam Google Drive atau sesuai
            preference kamu.
          </div>
