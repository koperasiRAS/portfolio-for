---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Web Development | Frame Of Rangga"
  description="Jasa pembuatan website profesional portfolio, landing page, company profile, dan web app yang responsive, fast, dan berorientasi pada pengalaman pengguna."
  ogImage="https://for-portfolio-mu.vercel.app/assets/og/og-website.jpg"
  ogUrl="https://for-portfolio-mu.vercel.app/website"
  hasGlightbox={true}
>
  <Navbar slot="navbar" activePage="website" />

  <!-- ====== STITCH HERO ====== -->
  <section class="web-stitch-hero" transition:animate="fade">
    <div class="hero-bg-glow" aria-hidden="true"></div>
    <div class="web-stitch-hero-inner">
      <!-- Heading -->
      <h1 class="web-stitch-title">
        High-Performance<br />
        <span class="web-stitch-title-accent"><em>Digital Ecosystems</em></span>
      </h1>
      <!-- Description -->
      <p class="web-stitch-hero-sub">
        Jasa pembuatan website profesional portfolio, landing page, company profile, dan web app yang responsif, cepat, dan berorientasi pada pengalaman pengguna.
      </p>
    </div>
  </section>

  <!-- ====== PROJECTS Stitch Browser Frame Layout ====== -->
  <section class="web-projects" id="projects" transition:animate="fade">

    <!-- Filter Bar -->
    <div class="filter-bar fade-up" aria-label="Filter by category">
      <button class="filter-btn active" data-filter="all">Semua</button>
      <button class="filter-btn" data-filter="portfolio">Portfolio</button>
      <button class="filter-btn" data-filter="landing">Landing Page</button>
      <button class="filter-btn" data-filter="sistem">Sistem Sederhana</button>
      <button class="filter-btn" data-filter="company">Company Profile</button>
    </div>

    <!-- Project One: Image Left / Info Right -->
    <div class="web-project-row web-project-row-normal" data-category="portfolio">
      <div class="web-project-browser-wrap">
        <div class="web-project-browser-frame">
          <!-- Browser chrome -->
          <div class="web-browser-chrome">
            <div class="web-browser-dots">
              <span class="web-browser-dot web-browser-dot-red"></span>
              <span class="web-browser-dot web-browser-dot-yellow"></span>
              <span class="web-browser-dot web-browser-dot-green"></span>
            </div>
            <div class="web-browser-url-bar">
              for-portfolio-mu.vercel.app
            </div>
          </div>
          <!-- Screenshot -->
          <a class="glightbox web-screenshot-link"
             href="/assets/thumbnails/web1.png"
             data-gallery="web-gallery"
             data-title="Web Portfolio: Frame Of Rangga">
            <img
              src="/assets/thumbnails/web1.png"
              alt="Web Portfolio Frame Of Rangga"
              loading="lazy"
              width="960"
              height="540"
            />
          </a>
        </div>
      </div>
      <div class="web-project-info">
        <span class="web-project-badge web-project-badge-purple">Portfolio Website</span>
        <h2 class="web-project-title">Web Portfolio: Frame Of Rangga</h2>
        <p class="web-project-desc">
          Portfolio website personal dengan Astro framework, featuring dark glassmorphism design yang elegan dan modern. Fast loading, responsive, dan optimized untuk SEO.
        </p>
        <div class="web-project-tech">
          <span class="web-tech-pill">Astro</span>
          <span class="web-tech-pill">CSS</span>
          <span class="web-tech-pill">JavaScript</span>
          <span class="web-tech-pill">Vercel</span>
        </div>
        <div class="web-project-links">
          <a href="https://for-portfolio-mu.vercel.app" target="_blank" rel="noopener noreferrer" class="web-project-link web-project-link-primary">
            <i class="fas fa-external-link-alt"></i> Kunjungi Website
          </a>
          <a href="https://wa.me/6287779560264?text=Halo%20Rangga%2C%20saya%20tertarik%20dengan%20web%20portfolio%20anda" target="_blank" rel="noopener noreferrer" class="web-project-link web-project-link-ghost">
            <i class="fab fa-whatsapp"></i> Tanya Project
          </a>
        </div>
      </div>
    </div>

    <!-- Project Two: Info Left / Image Right (inverse) -->
    <div class="web-project-row web-project-row-inverse" data-category="landing">
      <div class="web-project-info">
        <span class="web-project-badge web-project-badge-blue">Landing Page</span>
        <h2 class="web-project-title">Landing Page: Client Project</h2>
        <p class="web-project-desc">
          Landing page yang didesain untuk mengkonversi visitor jadi leads. Dengan CTA yang jelas, layout yang clean, dan pengalaman pengguna yang seamless di semua device.
        </p>
        <div class="web-project-tech">
          <span class="web-tech-pill">HTML</span>
          <span class="web-tech-pill">CSS</span>
          <span class="web-tech-pill">JavaScript</span>
        </div>
        <div class="web-project-links web-project-links-right">
          <span class="web-demo-label" style="color: var(--text-secondary); font-size: 12px; margin-right: auto;">Live demo available on request</span>
          <a href="https://wa.me/6287779560264?text=Halo%20Rangga%2C%20saya%20tertarik%20dengan%20jasa%20pembuatan%20website" target="_blank" rel="noopener noreferrer" class="web-project-link web-project-link-ghost">
            <i class="fab fa-whatsapp"></i> Tanya Project
          </a>
        </div>
      </div>
      <div class="web-project-browser-wrap">
        <div class="web-project-browser-frame">
          <!-- Browser chrome -->
          <div class="web-browser-chrome">
            <div class="web-browser-dots">
              <span class="web-browser-dot web-browser-dot-red"></span>
              <span class="web-browser-dot web-browser-dot-yellow"></span>
              <span class="web-browser-dot web-browser-dot-green"></span>
            </div>
            <div class="web-browser-url-bar">
              <i class="fas fa-lock" style="font-size:9px;opacity:0.5;margin-right:4px;"></i>by request via WhatsApp
            </div>
          </div>
          <!-- Screenshot -->
          <a class="glightbox web-screenshot-link"
             href="/assets/thumbnails/landing-placeholder.svg"
             data-gallery="web-gallery"
             data-title="Landing Page: Client Project">
            <img
              src="/assets/thumbnails/landing-placeholder.svg"
              alt="Landing Page Client Project"
              loading="lazy"
              width="960"
              height="540"
            />
          </a>
        </div>
      </div>
    </div>

    <!-- Project Three: Sistem Sederhana (POS) -->
    <div class="web-project-row web-project-row-normal" data-category="sistem">
      <div class="web-project-browser-wrap">
        <div class="web-project-browser-frame">
          <!-- Browser chrome -->
          <div class="web-browser-chrome">
            <div class="web-browser-dots">
              <span class="web-browser-dot web-browser-dot-red"></span>
              <span class="web-browser-dot web-browser-dot-yellow"></span>
              <span class="web-browser-dot web-browser-dot-green"></span>
            </div>
            <div class="web-browser-url-bar">
              <i class="fas fa-lock" style="font-size:9px;opacity:0.5;margin-right:4px;"></i>by request via WhatsApp
            </div>
          </div>
          <!-- Screenshot -->
          <a class="glightbox web-screenshot-link"
             href="/assets/thumbnails/pos-placeholder.svg"
             data-gallery="web-gallery"
             data-title="Sistem POS Point of Sale">
            <img
              src="/assets/thumbnails/pos-placeholder.svg"
              alt="Sistem POS Point of Sale"
              loading="lazy"
              width="960"
              height="540"
            />
          </a>
        </div>
      </div>
      <div class="web-project-info">
        <span class="web-project-badge web-project-badge-green">Sistem Sederhana</span>
        <h2 class="web-project-title">Sistem POS Point of Sale</h2>
        <p class="web-project-desc">
          Aplikasi kasir sederhana untuk UMKM. Fitur: input produk, transaksi, laporan harian. Dirancang praktis dan mudah digunakan untuk pelaku usaha kecil.
        </p>
        <div class="web-project-tech">
          <span class="web-tech-pill">HTML</span>
          <span class="web-tech-pill">CSS</span>
          <span class="web-tech-pill">JavaScript</span>
          <span class="web-tech-pill">Laragon</span>
        </div>
        <div class="web-project-links">
          <span class="web-demo-label" style="color: var(--text-secondary); font-size: 12px; margin-right: auto;">Live demo available on request</span>
          <a href="https://wa.me/6287779560264?text=Halo%20Rangga%2C%20saya%20tertarik%20dengan%20jasa%20pembuatan%20website" target="_blank" rel="noopener noreferrer" class="web-project-link web-project-link-ghost">
            <i class="fab fa-whatsapp"></i> Tanya Project
          </a>
        </div>
      </div>
    </div>

    <!-- Project Four: Landing Page Tambahan -->
    <div class="web-project-row web-project-row-inverse" data-category="landing">
      <div class="web-project-info">
        <span class="web-project-badge web-project-badge-blue">Landing Page</span>
        <h2 class="web-project-title">Landing Page Produk &amp; Brand</h2>
        <p class="web-project-desc">
          Landing page konversi tinggi untuk campaign produk atau brand promotion. Dirancang dengan CTA yang jelas dan layout yang clean untuk hasil maksimal.
        </p>
        <div class="web-project-tech">
          <span class="web-tech-pill">HTML</span>
          <span class="web-tech-pill">CSS</span>
          <span class="web-tech-pill">JavaScript</span>
        </div>
        <div class="web-project-links web-project-links-right">
          <span class="web-demo-label" style="color: var(--text-secondary); font-size: 12px; margin-right: auto;">Live demo available on request</span>
          <a href="https://wa.me/6287779560264?text=Halo%20Rangga%2C%20saya%20tertarik%20dengan%20jasa%20pembuatan%20website" target="_blank" rel="noopener noreferrer" class="web-project-link web-project-link-ghost">
            <i class="fab fa-whatsapp"></i> Tanya Project
          </a>
        </div>
      </div>
      <div class="web-project-browser-wrap">
        <div class="web-project-browser-frame">
          <!-- Browser chrome -->
          <div class="web-browser-chrome">
            <div class="web-browser-dots">
              <span class="web-browser-dot web-browser-dot-red"></span>
              <span class="web-browser-dot web-browser-dot-yellow"></span>
              <span class="web-browser-dot web-browser-dot-green"></span>
            </div>
            <div class="web-browser-url-bar">
              <i class="fas fa-lock" style="font-size:9px;opacity:0.5;margin-right:4px;"></i>by request via WhatsApp
            </div>
          </div>
          <!-- Screenshot -->
          <a class="glightbox web-screenshot-link"
             href="/assets/thumbnails/landing-placeholder.svg"
             data-gallery="web-gallery"
             data-title="Landing Page Produk & Brand">
            <img
              src="/assets/thumbnails/landing-placeholder.svg"
              alt="Landing Page Produk dan Brand"
              loading="lazy"
              width="960"
              height="540"
            />
          </a>
        </div>
      </div>
    </div>

    <!-- Bento Stats Grid Stitch Style -->
    <div class="web-stitch-bento">
      <div class="web-stitch-bento-cta">
        <h3 class="web-stitch-bento-title">Siap meningkatkan kehadiran digital Anda?</h3>
        <p class="web-stitch-bento-desc">
          Kami tidak sekadar membangun website — kami merancang pengalaman digital yang mengubah perhatian menjadi kepercayaan.
        </p>
      </div>
      <div class="web-stitch-bento-stat">
        <i class="fas fa-rocket web-stitch-bento-icon"></i>
        <div class="web-stitch-bento-value">98/100</div>
        <div class="web-stitch-bento-label">Lighthouse Score</div>
      </div>
      <div class="web-stitch-bento-stat">
        <i class="fas fa-mobile-screen-button web-stitch-bento-icon"></i>
        <div class="web-stitch-bento-value">Fluid</div>
        <div class="web-stitch-bento-label">Mobile Optimized</div>
      </div>
    </div>

  </section>

  <Footer slot="footer" variant="minimal" />
</BaseLayout>

<style>
  /* =============================================
     STITCH WEBSITE PAGE Scoped styles
     Matches: stitch/website_development_redesign/code.html
     ============================================= */

  /* ---- HERO ---- */
  .web-stitch-hero {
    padding: 140px 48px 80px;
    max-width: 1280px;
    margin: 0 auto;
    border-bottom: 1px solid rgba(64, 72, 93, 0.15);
  }

  .web-stitch-hero-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0;
  }

  .web-stitch-title {
    font-family: 'Manrope', sans-serif;
    font-size: clamp(40px, 6vw, 80px);
    font-weight: 800;
    letter-spacing: -1.5px;
    line-height: 1.05;
    color: var(--text-primary);
    margin-bottom: 36px;
  }

  .web-stitch-title-accent {
    display: block;
    color: var(--accent-primary);
    font-style: italic;
    font-weight: 300;
  }

  .web-stitch-hero-sub {
    font-size: 17px;
    line-height: 1.7;
    color: var(--text-secondary);
    max-width: 600px;
    margin: 0 auto;
  }

  /* ---- PROJECTS SECTION ---- */
  .web-projects {
    padding: 80px 48px;
    max-width: 1280px;
    margin: 0 auto;
  }

  /* Filter Bar */
  .filter-bar {
    margin-bottom: 80px;
  }

  .filter-btn {
    background: var(--surface-container-highest);
    border: 1px solid rgba(163, 166, 255, 0.08);
    color: var(--text-secondary);
    font-family: 'Inter', sans-serif;
    font-weight: 600;
    font-size: 13px;
    padding: 9px 22px;
    border-radius: 9999px;
    cursor: pointer;
    white-space: nowrap;
    transition: all 0.3s ease;
  }

  .filter-btn:hover {
    background: var(--surface-bright);
    color: var(--accent-primary);
    border-color: rgba(163, 166, 255, 0.15);
    transform: translateY(-2px);
  }

  .filter-btn.active {
    background: var(--accent-secondary-container);
    border-color: rgba(193, 128, 255, 0.3);
    color: #e9cdff;
  }

  /* Project Row 12-col grid */
  .web-project-row {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: 48px;
    align-items: center;
    margin-bottom: 96px;
  }

  /* Normal: image left (7 cols) + info right (5 cols) */
  .web-project-row-normal .web-project-browser-wrap {
    grid-column: span 7;
  }

  .web-project-row-normal .web-project-info {
    grid-column: span 5;
  }

  /* Inverse: info left (5 cols) + image right (7 cols) */
  .web-project-row-inverse .web-project-info {
    grid-column: span 5;
    text-align: right;
    order: 1;
  }

  .web-project-row-inverse .web-project-browser-wrap {
    grid-column: span 7;
    order: 2;
  }

  /* Browser Frame */
  .web-project-browser-wrap {
    position: relative;
  }

  /* Glow behind browser */
  .web-project-browser-wrap::before {
    content: '';
    position: absolute;
    inset: -12px;
    border-radius: 2rem;
    background: linear-gradient(135deg, rgba(163, 166, 255, 0.12), rgba(193, 128, 255, 0.12));
    filter: blur(24px);
    opacity: 0.6;
    transition: opacity 0.4s ease;
    z-index: 0;
  }

  .web-project-browser-wrap:hover::before {
    opacity: 1;
  }

  /* Inverse glow color */
  .web-project-row-inverse .web-project-browser-wrap::before {
    background: linear-gradient(135deg, rgba(105, 156, 255, 0.12), rgba(163, 166, 255, 0.12));
  }

  .web-project-browser-frame {
    position: relative;
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid rgba(64, 72, 93, 0.25);
    box-shadow: 0 32px 80px rgba(0, 0, 0, 0.5);
    z-index: 1;
    background: var(--surface-container);
  }

  /* Browser chrome bar */
  .web-browser-chrome {
    background: var(--surface-container-highest);
    padding: 12px 16px;
    display: flex;
    align-items: center;
    gap: 8px;
    border-bottom: 1px solid rgba(64, 72, 93, 0.2);
  }

  .web-browser-dots {
    display: flex;
    gap: 6px;
    flex-shrink: 0;
  }

  .web-browser-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
  }

  .web-browser-dot-red { background: rgba(215, 51, 87, 0.5); }
  .web-browser-dot-yellow { background: rgba(105, 156, 255, 0.5); }
  .web-browser-dot-green { background: rgba(163, 166, 255, 0.5); }

  .web-browser-url-bar {
    flex: 1;
    text-align: center;
    background: var(--surface-container-low);
    border-radius: 6px;
    padding: 5px 12px;
    font-size: 10px;
    font-family: 'Inter', monospace;
    color: var(--text-secondary);
    letter-spacing: 0.02em;
    opacity: 0.6;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* Screenshot image */
  .web-screenshot-link {
    display: block;
  }

  .web-screenshot-link img {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }

  .web-project-browser-frame:hover .web-screenshot-link img {
    transform: scale(1.02);
  }

  /* Project Info */
  .web-project-info {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .web-project-badge {
    display: inline-flex;
    align-self: flex-start;
    padding: 5px 14px;
    border-radius: 9999px;
    background: var(--surface-container-highest);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    width: fit-content;
  }

  .web-project-badge-purple { color: var(--accent-secondary); }
  .web-project-badge-blue   { color: var(--accent-tertiary); }
  .web-project-badge-green  { color: #6bffb8; }

  .web-project-row-inverse .web-project-badge {
    align-self: flex-end;
  }

  .web-project-title {
    font-family: 'Manrope', sans-serif;
    font-size: clamp(28px, 3vw, 44px);
    font-weight: 700;
    color: var(--text-primary);
    letter-spacing: -0.5px;
    line-height: 1.1;
  }

  .web-project-desc {
    font-size: 15px;
    line-height: 1.75;
    color: var(--text-secondary);
  }

  /* Tech pills */
  .web-project-tech {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }

  .web-project-row-inverse .web-project-tech {
    justify-content: flex-end;
  }

  .web-tech-pill {
    padding: 5px 14px;
    border-radius: 9999px;
    border: 1px solid rgba(96, 99, 238, 0.3);
    color: var(--accent-primary-dim);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  /* Links */
  .web-project-links {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
  }

  .web-project-links-right {
    justify-content: flex-end;
  }

  .web-project-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 24px;
    border-radius: 9999px;
    font-family: 'Manrope', sans-serif;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .web-project-link i { font-size: 13px; }

  .web-project-link-primary {
    background: linear-gradient(135deg, var(--accent-primary), var(--accent-primary-dim));
    color: #0f00a4;
    box-shadow: 0 6px 20px rgba(163, 166, 255, 0.25);
  }

  .web-project-link-primary:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 28px rgba(163, 166, 255, 0.4);
  }

  .web-project-link-ghost {
    border: 1px solid rgba(64, 72, 93, 0.4);
    color: var(--text-primary);
  }

  .web-project-link-ghost:hover {
    background: var(--surface-bright);
    border-color: rgba(163, 166, 255, 0.3);
    transform: translateY(-3px);
  }

  /* ---- BENTO STATS GRID ---- */
  .web-stitch-bento {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: 20px;
    margin-top: 32px;
  }

  /* Glass panel base */
  .web-stitch-bento > * {
    background: rgba(25, 37, 64, 0.35);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(64, 72, 93, 0.15);
    border-radius: 24px;
  }

  /* CTA panel */
  .web-stitch-bento-cta {
    padding: 48px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .web-stitch-bento-title {
    font-family: 'Manrope', sans-serif;
    font-size: clamp(22px, 2.5vw, 32px);
    font-weight: 800;
    color: var(--text-primary);
    letter-spacing: -0.5px;
    margin-bottom: 16px;
    line-height: 1.2;
  }

  .web-stitch-bento-desc {
    font-size: 15px;
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 24px;
    max-width: 340px;
  }

  .web-stitch-bento-link {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    color: var(--accent-primary);
    font-family: 'Manrope', sans-serif;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    text-decoration: none;
    transition: gap 0.3s ease;
  }

  .web-stitch-bento-link:hover {
    gap: 14px;
  }

  .web-stitch-bento-link i {
    font-size: 14px;
    transition: transform 0.3s ease;
  }

  .web-stitch-bento-link:hover i {
    transform: translateX(4px);
  }

  /* Stat panels */
  .web-stitch-bento-stat {
    padding: 32px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    gap: 12px;
  }

  .web-stitch-bento-icon {
    font-size: 36px;
    color: var(--accent-primary);
    margin-bottom: 4px;
  }

  .web-stitch-bento-stat:nth-child(3) .web-stitch-bento-icon {
    color: var(--accent-secondary);
  }

  .web-stitch-bento-value {
    font-family: 'Manrope', sans-serif;
    font-size: 36px;
    font-weight: 800;
    color: var(--text-primary);
    line-height: 1;
    letter-spacing: -1px;
  }

  .web-stitch-bento-label {
    font-family: 'Manrope', sans-serif;
